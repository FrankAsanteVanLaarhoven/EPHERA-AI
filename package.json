{
  "name": "ephera",
  "private": true,
  "version": "0.1.0",
  "description": "EPHERA Money — enterprise voice-native mobile money, banking and commerce platform for Africa. Installable PWA, Expo mobile, double-entry ledger, Temporal payments, passkey authorisation.",
  "workspaces": [
    "apps/merchant-web",
    "apps/consumer-pwa",
    "apps/admin-console",
    "apps/provider-portal",
    "packages/*"
  ],
  "overrides": {
    "react-native": "0.76.9"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run test:financial-core",
    "test:financial-core": "cd native/financial-core && cargo test",
    "test:ledger": "cd services/ledger && go test ./...",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:merchant": "npm run dev -w @ephera/merchant-web",
    "dev:consumer-pwa": "npm run dev -w @ephera/consumer-pwa",
    "dev:admin": "npm run dev -w @ephera/admin-console",
    "dev:provider": "npm run dev -w @ephera/provider-portal",
    "mobile:start": "npm run start -w @ephera/mobile",
    "mobile:lan": "npm run start:lan -w @ephera/mobile",
    "mobile:web": "npm run web -w @ephera/mobile",
    "mobile:ios": "npm run ios -w @ephera/mobile",
    "mobile:android": "npm run android -w @ephera/mobile",
    "infra:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker-compose.yml down",
    "infra:logs": "docker compose -f infrastructure/docker-compose.yml logs -f",
    "db:migrate": "./scripts/db-migrate.sh",
    "db:psql": "docker compose -f infrastructure/docker-compose.yml exec postgres psql -U ephera -d ephera_ledger",
    "dev:payments-api": "./scripts/run-payments-api.sh",
    "dev:payments-worker": "./scripts/run-payments-worker.sh",
    "dev:ledger": "./scripts/run-ledger-api.sh",
    "dev:voice-intent": "./scripts/run-voice-intent.sh",
    "test:go": "cd services/payments && go test ./...",
    "test:voice": "cd services/voice-intent && python3 -m pytest -q || python3 -c 'import test_compiler; test_compiler.test_send_ama(); test_compiler.test_freeze(); test_compiler.test_never_authorises(); test_compiler.test_low_confidence_without_amount(); print(\"voice tests ok\")'"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10"
}
